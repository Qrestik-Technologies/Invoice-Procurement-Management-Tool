# Database (Docker Compose — use hostnames postgresql/redis)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgresql:5432/invoice_tool
# Local dev without Docker — uncomment these instead:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/invoice_tool
# REDIS_URL=redis://localhost:6379/0

# Redis
REDIS_URL=redis://redis:6379/0

# Application environment
APP_ENV=production
DEBUG=false

# JWT (use 32+ random chars in production)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# SendGrid
SENDGRID_API_KEY=
COMPANY_EMAIL=

# Microsoft OneDrive / Graph API
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_DRIVE_ID=

# App
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=20971520
COMPANY_NAME=Qrestik Services LLC
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-password
ADMIN_NAME=Admin

# TLS (production — used by Caddy)
DOMAIN=invoices.yourdomain.com

# Login rate limiting
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=300
